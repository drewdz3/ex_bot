# Azure OpenAI Configuration
# Copy your actual values from Azure Portal here

# From Azure Portal -> Your OpenAI Resource -> Keys and Endpoint
AZURE_OPENAI_API_KEY=your_api_key_from_azure_portal
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-06-01

# Azure AD B2C Configuration
# From Azure Portal -> Your B2C Tenant -> App registrations
AZURE_B2C_TENANT_NAME=your_tenant_name_here
AZURE_B2C_CLIENT_ID=your_app_client_id_here
AZURE_B2C_POLICY_SIGNIN=B2C_1_signupsignin
AZURE_B2C_POLICY_EDIT_PROFILE=B2C_1_profileedit
AZURE_B2C_POLICY_PASSWORD_RESET=B2C_1_passwordreset

# Instructions:
# 1. Replace the values above with your actual Azure OpenAI credentials
# 2. In PowerShell, run these commands to set environment variables:
#    $env:AZURE_OPENAI_API_KEY="your_actual_key"
#    $env:AZURE_OPENAI_ENDPOINT="your_actual_endpoint"
#    $env:AZURE_OPENAI_DEPLOYMENT_NAME="your_deployment_name"
#    $env:AZURE_OPENAI_API_VERSION="2024-06-01"
# 3. Or copy the values to the temporary config file (see below)