# Azure OpenAI Configuration
# Copy your actual values from Azure Portal here

# From Azure Portal -> Your OpenAI Resource -> Keys and Endpoint
AZURE_OPENAI_API_KEY=your_api_key_from_azure_portal
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-06-01

# Azure AD B2C Configuration
# From Azure Portal -> Your B2C Tenant -> App registrations
AUTH_TENANT_ID=
AUTH_CLIENT_ID=
AUTH_REDIRECT_URI=
AUTH_ISSUER=
AUTH_DISCOVERY_URL=
AUTH_SCOPES=openid,profile,email,offline_access